{
  "compilerOptions": {
    "target": "esnext",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,    
    "module": "nodenext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  }
}